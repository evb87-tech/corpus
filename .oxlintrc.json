{
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "warn",
    "style": "warn"
  },
  "rules": {
    "no-console": "off",
    "no-debugger": "error",
    "eqeqeq": "error",
    "no-var": "error",
    "no-eval": "error",
    "unicorn/no-null": "off",
    "no-magic-numbers": "off",
    "max-statements": "off",
    "max-lines-per-function": "off",
    "id-length": "off"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "coverage",
    "raw",
    "wiki",
    "output",
    ".beads",
    ".claude"
  ]
}

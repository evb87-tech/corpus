{
  "name": "corpus",
  "version": "0.1.0",
  "description": "Local file-based second brain — raw → wiki → output, agent-compiled.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:unit": "bun test src",
    "test:integration": "bun test src/**/__integration__",
    "test:e2e": "bun test src/**/__e2e__",
    "test:coverage": "bun test --coverage",
    "ci": "bun run format:check && bun run lint && bun run typecheck && bun run test:coverage",
    "build": "bun build src/main.ts --outdir dist --target bun"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^0.15.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
